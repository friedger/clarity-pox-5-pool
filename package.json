{
  "name": "clarity-pox-5-pool-tests",
  "version": "1.0.0",
  "description": "Run unit tests on this project.",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "rv:test": "node tests/rv/run.mjs test --runs 500",
    "rv:invariant": "node tests/rv/run.mjs invariant --runs 500"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@stacks/clarinet-sdk": "^3.20.0",
    "@stacks/transactions": "^7.5.0",
    "@types/node": "^26.0.0",
    "chokidar-cli": "^3.0.0",
    "vitest": "^4.1.9",
    "vitest-environment-clarinet": "^3.0.2"
  },
  "devDependencies": {
    "@stacks/rendezvous": "^1.0.1"
  }
}
